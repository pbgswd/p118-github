{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^3.5",
        "enlightn/enlightn": "^2.8",
        "google/recaptcha": "^1.2",
        "kyslik/column-sortable": "^6.6",
        "laravel/framework": "^11.23",
        "laravel/pail": "^1.1",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.4",
        "league/flysystem": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "nesbot/carbon": "^2.57",
        "predis/predis": "^1.1",
        "rtconner/laravel-tagging": "^4.1",
        "sendgrid/sendgrid": "^8.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/image": "^3.0",
        "spatie/laravel-image-optimizer": "^1.8",
        "spatie/laravel-permission": "^6.2",
        "spatie/laravel-searchable": "^1.12.0",
        "spatie/laravel-sitemap": "^7.2",
        "symfony/http-client": "^7.0",
        "symfony/mailgun-mailer": "^7.0",
        "unicodeveloper/laravel-password": "^1.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^10.5",
        "fakerphp/faker": "^1.23",
        "jasonmccreary/laravel-test-assertions": "^2.4",
        "laravel-shift/factory-generator": "dev-master"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform-check": false
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Http\\": "app/Http/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ]
    }
}
